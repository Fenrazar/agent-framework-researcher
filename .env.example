# ============================================================================
# Agent Framework Researcher — Environment Variables
# ============================================================================

# --- LLM Provider -----------------------------------------------------------
# Set to "openai" (default) or "azure".
# Auto-detected as "azure" when LLM_ENDPOINT is set.
# LLM_PROVIDER=openai
LLM_API_KEY=sk-...
# LLM_ENDPOINT=https://your-resource.openai.azure.com/  # Set for Azure OpenAI

# --- Models ------------------------------------------------------------------
# DEFAULT_MODEL is used for all tasks unless overridden by a per-task model.
# DEFAULT_MODEL=gpt-4.1
# RESEARCH_MODEL=gpt-4.1              # Falls back to DEFAULT_MODEL
# RESEARCH_MODEL_MAX_TOKENS=10000
# COMPRESSION_MODEL=gpt-4.1           # Falls back to DEFAULT_MODEL
# COMPRESSION_MODEL_MAX_TOKENS=10000
# FINAL_REPORT_MODEL=gpt-4.1          # Falls back to DEFAULT_MODEL
# FINAL_REPORT_MODEL_MAX_TOKENS=50000

# --- Research Behavior -------------------------------------------------------
# SEARCH_API=web_search                # "web_search" or "none"
# ALLOW_CLARIFICATION=true             # Ask user clarifying questions
# MAX_CONCURRENT_RESEARCH_UNITS=5      # Parallel researcher agents
# MAX_RESEARCHER_ITERATIONS=6          # Supervisor delegation rounds
# MAX_REACT_TOOL_CALLS=10              # Tool calls per researcher
# MAX_STRUCTURED_OUTPUT_RETRIES=3      # JSON parse retries

# --- MCP (optional) ----------------------------------------------------------
# MCP_PROMPT=                          # Extra instructions for MCP tools
